{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"outDir": "./lib",
		"declaration": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["DOM", "ES2020"],
		"jsx": "preserve",
		"resolveJsonModule": true,
		"moduleResolution": "node"
	},
	"include": ["./src/**/*.ts"]
}
